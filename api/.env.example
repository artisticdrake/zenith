SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
OPENAI_API_KEY2=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
PORT=3000

# Stage 4 — job-triage internal scoring path (machine auth for Phase 2 n8n/Apify).
# POST /internal/score-job requires the 'x-internal-key' header to equal INTERNAL_API_KEY,
# and scores against the owner derived from INTERNAL_USER_ID (NEVER the request body).
INTERNAL_API_KEY=a_long_random_shared_secret
INTERNAL_USER_ID=the_supabase_auth_user_uuid_that_owns_scraped_jobs
# Max jobs accepted by POST /internal/score-jobs (batch) in a single call. A larger
# batch is rejected 400 so a runaway scrape can't fan out into hundreds of scorer
# calls by accident. Optional; defaults to 150.
INTERNAL_BATCH_MAX=150
# Per-IP requests/minute allowed on /internal/* so a leaked INTERNAL_API_KEY can't
# run up unbounded scorer calls. Optional; defaults to 60.
INTERNAL_RATE_LIMIT_PER_MIN=60

# ── Apify scrapers (Stage 5 — scrape-and-score) ───────────────────────────────
# POST /internal/scrape-and-score runs the BuiltIn actor (solidcode/builtin-scraper)
# with fetchDescription:true and scores the results through the existing pipeline.
# APIFY_TOKEN is your Apify API token (the code also accepts the legacy name
# APIFY_API_KEY). Never commit the real value. Must be set locally AND on Railway.
APIFY_TOKEN=your_apify_api_token_here
# Hard cap on results pulled per scrape call so one request can't run up an
# unbounded (costly) scrape. Optional; defaults to 100.
APIFY_MAX_RESULTS=100

# ── Deployment (Railway / public internet) ────────────────────────────────────
# Comma-separated browser origins allowed by CORS (your deployed web frontend, and
# localhost for dev). If unset, ALL origins are allowed — set this in production.
# Server-to-server callers (n8n Cloud → /internal/*) send no Origin and are always
# allowed regardless of this list.
CORS_ALLOWED_ORIGINS=https://your-frontend.example.com,http://localhost:5173
# PORT is provided by Railway automatically; do NOT hardcode it there. Local dev
# falls back to 3000.
